# OpenAI translation adapter.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# Target repository for generated translation PRs.
KREW_REPO=Hugging-Face-KREW/hugging-face-krew.github.io

# Skill repositories that receive repository_dispatch events.
SEO_SKILLS_REPO=Hugging-Face-KREW/seo-skills
QUALITY_SKILLS_REPO=Hugging-Face-KREW/quality-skills

# Fine-grained GitHub token used for cloning/pushing to KREW_REPO, opening PRs,
# and dispatching SEO/quality workflows.
# Required permissions:
# - Contents: read/write on KREW_REPO
# - Pull requests: read/write on KREW_REPO
# - Actions: read/write on seo/quality skill repos
#
# Local PR creation currently uses the GitHub CLI, so also run:
#   gh auth login
GITHUB_TOKEN=
